{
  "name": "foco-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "node ./node_modules/jest/bin/jest.js",
    "test:watch": "node ./node_modules/jest/bin/jest.js --watch",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit",
    "tokens:build": "node tokens/build-tokens.mjs",
    "tokens:sync": "node tokens/build-tokens.mjs && cp tokens/build/theme.generated.ts constants/theme.ts",
    "figma:connect": "figma connect publish"
  },
  "dependencies": {
    "@expo-google-fonts/fraunces": "^0.4.1",
