    "axios": "^1.16.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-background-fetch": "~14.0.9",
    "expo-blur": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "^8.0.12",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "lucide-react-native": "^1.14.0",
